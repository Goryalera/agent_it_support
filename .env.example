# ── AskOps: шаблон переменных окружения ─────────────────────────────────────
# Скопируй этот файл в .env и заполни значения.
# .env НЕ коммитится (см. .gitignore). Здесь — только пустые шаблоны.

# Режим LLM: real | mock
# mock — отвечает заглушкой без обращения к провайдеру (для тестов/CI/демо без кредов)
LLM_MODE=real
# Провайдер при LLM_MODE=real: gigachat | openrouter
LLM_PROVIDER=gigachat

# ── GigaChat ────────────────────────────────────────────────────────────────
# Креды для физлиц с developers.sber.ru (Authorization key, base64).
GIGACHAT_CREDENTIALS=
# Область доступа: GIGACHAT_API_PERS (физлица) | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модель GigaChat
GIGACHAT_MODEL=GigaChat
# Проверять ли TLS-сертификаты Сбера (false — проще для локалки)
GIGACHAT_VERIFY_SSL_CERTS=false

# ── OpenRouter (OpenAI-совместимый API) ─────────────────────────────────────
# Чтобы запустить с DeepSeek: поставь LLM_PROVIDER=openrouter и заполни ключ.
# Ключ — с openrouter.ai/keys.
OPENROUTER_API_KEY=
# Модель OpenRouter (по умолчанию DeepSeek V4 Flash)
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Необязательные заголовки для статистики приложения на openrouter.ai
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=AskOps

# ── Эмбеддинги (sentence-transformers, локально) ────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Размерность должна совпадать с полем knn_vector в индексе (для модели выше = 384)
EMBEDDING_DIM=384

# ── OpenSearch ──────────────────────────────────────────────────────────────
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=askops-kb

# ── RAG-агент ───────────────────────────────────────────────────────────────
RAG_HOST=0.0.0.0
RAG_PORT=8001
# URL RAG-агента для A2A-клиента оркестратора (внутри compose-сети)
RAG_AGENT_URL=http://rag:8001
# Сколько кусков подмешивать в контекст
RAG_TOP_K=4

# ── Аналитик-агент (Слой 1) ─────────────────────────────────────────────────
ANALYST_HOST=0.0.0.0
ANALYST_PORT=8002
# URL аналитик-агента для A2A-клиента оркестратора (внутри compose-сети)
ANALYST_AGENT_URL=http://analyst:8002
# Путь к SQLite-базе тикетов (аналитик открывает её read-only)
TICKETS_DB_PATH=/app/data/tickets.db
# Максимум строк в результате сгенерированного SELECT (защита от тяжёлых выборок)
ANALYST_MAX_ROWS=200
# Сколько синтетических тикетов сгенерировать при первом старте
TICKETS_COUNT=5000

# ── Action-агент и очередь (Слой 2; профиль "action") ───────────────────────
ACTION_HOST=0.0.0.0
ACTION_PORT=8003
# URL action-агента для A2A-клиента оркестратора (внутри compose-сети)
ACTION_AGENT_URL=http://action:8003
# Kafka-совместимый брокер (Redpanda). Внутри compose-сети — redpanda:9092,
# с хоста (локальный запуск) — localhost:19092.
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_TOPIC=ticket-events
# Таймаут соединения с брокером (сек) — чтобы создание тикета не зависало
KAFKA_TIMEOUT=5

# ── Агент-нотификатор (Слой 2; профиль "action") ────────────────────────────
NOTIFIER_HOST=0.0.0.0
NOTIFIER_PORT=8004
# Куда нотификатор «отправляет» уведомления (файл в общем volume + консоль)
NOTIFICATIONS_FILE=/app/data/notifications.log
KAFKA_CONSUMER_GROUP=askops-notifier

# ── Оркестратор ─────────────────────────────────────────────────────────────
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000

# ── Streamlit UI ────────────────────────────────────────────────────────────
# URL оркестратора для UI (внутри compose-сети)
ORCHESTRATOR_URL=http://orchestrator:8000
